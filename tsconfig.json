{
    "compilerOptions": {
      "strict": true,
      "types": [],
      "inlineSourceMap": true,
      "inlineSources": true,
      "module": "ESNext",
      "target": "ES6",
      "allowJs": true,
      "moduleResolution": "bundler",
      "importHelpers": true,
      "isolatedModules": true,
      "skipLibCheck": true,
      "lib": [
        "DOM",
        "ES2015",
        "ES2016",
        "ES2017",
        "ES2018",
        "ES2019",
        "ES2020"
      ]
    },
    "include": [
      "**/*.ts"
    ]
  }
